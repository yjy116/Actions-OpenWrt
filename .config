# 硬件平台定义
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt3600be=y

# --- 核心无线驱动补全 (修复 2.4G 缺失) ---
CONFIG_PACKAGE_kmod-mt798x-firmware=y
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_kmod-mt7915e-firmware=y
CONFIG_PACKAGE_wpad-openssl=y

# --- 全锥型 NAT 与网络加速 ---
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_SHORTCUT_FE=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_FULLCONENAT=y
CONFIG_PACKAGE_kmod-iptables-mod-fullconenat=y

# --- 科学上网与 DNS (根据你之前的列表) ---
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-mosdns=y

# --- 远程访问与内网穿透 ---
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-app-wolplus=y

# --- 硬件扩展 (打印机、共享、磁盘) ---
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-usb-printer=y
CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_luci-app-partexp=y

# --- 系统增强与界面 ---
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-netspeedtest=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-autocore=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# 界面美化
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# 移除不必要的调试信息以减小固件体积并加快编译
# CONFIG_DEBUG_INFO is not set
